# Server config
PORT=3000
NODE_ENV=development

# Database (Prisma)
DATABASE_URL="postgresql://user:password@localhost:5432/maplore_db?schema=public"

# Auth
JWT_SECRET=your_jwt_secret_here
JWT_ACCESS_TOKEN_EXPIRES_IN=1h
JWT_REFRESH_TOKEN_EXPIRES_IN_DAYS=7
CLIENT_URL=http://localhost:5173

# Rate Limit
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
LOGIN_LIMIT_WINDOW_MS=900000
LOGIN_LIMIT_MAX=10
